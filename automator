#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_PYTHON="$ROOT_DIR/.venv/bin/python3"

if [[ -x "$VENV_PYTHON" ]]; then
  exec "$VENV_PYTHON" "$ROOT_DIR/engine/automator.py" "$@"
fi

if ! python3 -c "import sys; sys.exit(0 if sys.version_info >= (3, 10) else 1)" 2>/dev/null; then
  echo "Error: automator requires Python 3.10 or later. Found: $(python3 --version 2>&1)" >&2
  exit 1
fi

exec python3 "$ROOT_DIR/engine/automator.py" "$@"
