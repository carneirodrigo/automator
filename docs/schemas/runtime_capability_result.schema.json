{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runtime_capability_result.schema.json",
  "title": "Runtime Capability Result",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "capability": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "blocked",
        "failed"
      ]
    },
    "result": {
      "type": [
        "object",
        "array",
        "string",
        "number",
        "boolean",
        "null"
      ]
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "capability",
    "status",
    "result",
    "issues"
  ]
}
