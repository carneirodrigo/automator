{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "runtime_capability_request.schema.json",
  "title": "Runtime Capability Request",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "capability": {
      "type": "string",
      "enum": [
        "read_file",
        "read_file_lines",
        "write_file",
        "stat_file",
        "list_dir",
        "find_files",
        "search_code",
        "run_command",
        "run_tests",
        "load_artifact",
        "persist_artifact",
        "load_memory",
        "save_memory",
        "test_credentials",
        "load_secrets",
        "save_secret",
        "fetch_skill",
        "get_kb_candidates",
        "fetch_source",
        "search_sources",
        "query_git_status",
        "query_git_diff",
        "query_git_log",
        "http_request_with_secret_binding",
        "validate_logic_app_workflow",
        "deploy_logic_app_definition",
        "create_sharepoint_list_schema",
        "create_powerbi_import_bundle",
        "powerbi_import_artifact",
        "powerbi_trigger_refresh",
        "powerbi_check_refresh_status"
      ]
    },
    "arguments": {
      "type": "object"
    },
    "reason": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "capability",
    "arguments",
    "reason"
  ]
}
