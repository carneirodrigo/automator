    },

    "api_name_to_managed_api_path": {
      "description": "The 'id' field in each connection entry follows the pattern: /subscriptions/{subId}/providers/Microsoft.Web/locations/{region}/managedApis/{apiName}",
      "mappings": {
        "azuresentinel": "Microsoft Sentinel (legacy connector key)",
        "Azuresentinel": "Microsoft Sentinel (MSI-capable variant, note capital A)",
        "microsoftsentinel": "Microsoft Sentinel (newer connector key)",
        "azuread": "Azure Active Directory / Entra ID connector",
        "office365": "Office 365 Outlook connector",
        "sharepointonline": "SharePoint Online connector",
        "wdatp": "Microsoft Defender for Endpoint (Windows Defender ATP) connector"
      }
    },

    "multiple_connections_same_api": {
      "description": "A single workflow can reference multiple connections to the same managed API (e.g., one for the trigger using MSI, another for actions using a service account). Each gets a unique key in the $connections object. Suffixes like _1, _2 or descriptive names are common.",
      "example_pattern": {
        "azuresentinel": "Used for trigger (MSI-authenticated Sentinel connection)",
        "azuresentinel_1": "Used for Entities actions (service-account Sentinel connection)",
        "azuread": "Used for AAD group and user operations",
        "azuread_1": "Alternative AAD connection"
      }
    }
  }
}
